# ═══════════════════════════════════════════════════════
# Hadi Perfumes API — Environment Configuration
# ═══════════════════════════════════════════════════════
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ── Database (required) ──────────────────────────────
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/hadi_perfumes"

# ── Auth (required) ──────────────────────────────────
JWT_SECRET=GENERATE_A_64_CHAR_HEX_STRING_HERE

# ── Redis (required for queue jobs) ──────────────────
REDIS_URL=redis://localhost:6379

# ── Supabase (required for media uploads) ────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_KEY
SUPABASE_STORAGE_BUCKET=media

# ── CORS ─────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── Server ───────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Legacy (no longer used — kept for reference) ─────
# ADMIN_TOKEN=no_longer_used
# ADMIN_ACTOR_ID=00000000-0000-0000-0000-000000000000

# ── Optional: Stripe ─────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Job Config (defaults shown) ──────────────────────
# COMMISSION_RELEASE_BATCH_SIZE=100
# COMMISSION_CALC_BATCH_SIZE=50
# COMMISSION_MAX_RETRIES=5
# MAX_NETWORK_DEPTH=5
# RESERVATION_TTL_SECONDS=900
# MIN_PAYOUT_AMOUNT_INR=100

# ── Trust Config (defaults shown) ────────────────────
# RETURN_WINDOW_DAYS=30
# DISPUTE_AUTO_ESCALATE_HOURS=72

# ── Throttle (defaults shown) ────────────────────────
# THROTTLE_TTL_SECONDS=60
# THROTTLE_LIMIT=100
